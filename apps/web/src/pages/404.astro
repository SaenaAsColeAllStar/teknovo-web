---
import BaseLayout from "../layouts/BaseLayout.astro";
import { TeknovoNotFoundPage } from "@/components/errors/TeknovoNotFoundPage";
---

{/* hideNavbar/hideFooter: pathname is `/404`, so chrome would otherwise still mount
    and BrandLogoMark can paint over the Beranda shortcut card under the overlay. */}
<BaseLayout title="Halaman tidak ditemukan" hideNavbar hideFooter>
  <TeknovoNotFoundPage client:load app="landing" escapePublicChrome />
</BaseLayout>
