---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { FasilitasAbsensiDigitalPage } from "@/components/features/landing/FasilitasAbsensiDigitalPage";
import { FasilitasDetailPage } from "@/components/features/landing/FasilitasDetailPage";
import { LmsJsonLd } from "@/components/features/lms/LmsJsonLd";
import {
  type FasilitasSlug,
  isFasilitasSlug,
} from "@/lib/fasilitas-landing-content";
import { LMS_PAGE_SEO } from "@/lib/lms-dashboard-seo";
import { getLmsPublikStats } from "@/services/lms-publik-stats";
import {
  getPublishedFasilitasBySlug,
  getPublishedFasilitasSlugs,
} from "@/services/fasilitas-publik";

export async function getStaticPaths() {
  const slugs = await getPublishedFasilitasSlugs();
  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const slug = Astro.params.slug as string;
const fromApi = await getPublishedFasilitasBySlug(slug);
const isAbsensi = slug === "absensi-digital";
const isLms = slug === "lms-sekolah";

if (!fromApi && !isAbsensi && !isLms) {
  return Astro.redirect("/fasilitas");
}

const typedSlug = (isFasilitasSlug(slug) ? slug : slug) as FasilitasSlug;
const liveStats = isLms ? await getLmsPublikStats() : undefined;
const item = fromApi;
const lmsSeo = LMS_PAGE_SEO["fasilitas-lms"];
const title = isLms ? lmsSeo.title : (item?.title ?? "Fasilitas");
const description = isLms
  ? lmsSeo.description
  : (item?.description ?? "Fasilitas SMK TEKNOVO");
---

<BaseLayout title={title} description={description}>
  {
    isAbsensi ? (
      <FasilitasAbsensiDigitalPage client:load />
    ) : (
      <>
        {isLms ? <LmsJsonLd pageId="fasilitas-lms" /> : null}
        <FasilitasDetailPage
          client:load
          slug={typedSlug}
          liveStats={liveStats}
          item={item}
        />
      </>
    )
  }
</BaseLayout>
