---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { AkademikHashRedirect } from "@/components/features/landing/AkademikHashRedirect";
import { AkademikKurikulumContent } from "@/components/features/landing/AkademikKurikulumContent";
import { LmsJsonLd } from "@/components/features/lms/LmsJsonLd";
import { LMS_PAGE_SEO } from "@/lib/lms-dashboard-seo";

const seo = LMS_PAGE_SEO["akademik-kurikulum"];
---

<BaseLayout title={seo.title} description={seo.description}>
  <AkademikHashRedirect client:load />
  <LmsJsonLd client:load pageId="akademik-kurikulum" />
  <AkademikKurikulumContent client:load />
</BaseLayout>
