---
import BaseLayout from "../layouts/BaseLayout.astro";
import { HomePage } from "../site/HomePage";
import { getPublishedArtikelSiswaCards } from "@/services/artikel-berita-publik";
import { getPublishedBeritaKegiatanCards } from "@/services/berita-kegiatan-publik";
import { getLandingPublicStats } from "@/services/landing-stats";
import { getLocalSeoPageConfig } from "@/lib/local-seo-keywords";

const [stats, artikelSiswa, beritaKegiatan] = await Promise.all([
  getLandingPublicStats(),
  getPublishedArtikelSiswaCards(12),
  getPublishedBeritaKegiatanCards(8),
]);

const seo = getLocalSeoPageConfig("home");
---

<BaseLayout title={seo.title} description={seo.description}>
  <HomePage
    client:load
    stats={stats}
    artikelSiswa={artikelSiswa}
    beritaKegiatan={beritaKegiatan}
  />
</BaseLayout>
