---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { BeritaArticleDetailShell } from "@/components/features/landing/berita/BeritaArticleDetailShell";
import {
  getBeritaKegiatanDetailPath,
  type BeritaArticleSeoInput,
} from "@/lib/berita-seo";
import { sanitizeArtikelHtml } from "@/lib/sanitize-artikel-html";
import { truncateMetaDescription } from "@/lib/seo/urls";
import {
  getBeritaKegiatanPublikBySlug,
  getRelatedBeritaKegiatan,
  listBeritaKegiatanSitemapEntries,
} from "@/services/berita-kegiatan-publik";

export async function getStaticPaths() {
  const entries = await listBeritaKegiatanSitemapEntries();
  return entries.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

const slug = Astro.params.slug!;
const artikel = await getBeritaKegiatanPublikBySlug(slug);
if (!artikel) {
  return Astro.redirect("/berita/kegiatan-sekolah");
}

const related = await getRelatedBeritaKegiatan(slug, 3);
const authorLabel =
  artikel.penulisNama?.trim() && artikel.penulisNama.trim().length > 0
    ? artikel.penulisNama.trim()
    : "Humas sekolah";
const coverAlt = artikel.coverAlt?.trim() || `Ilustrasi berita: ${artikel.judul}`;
const path = getBeritaKegiatanDetailPath(slug);
const seo: BeritaArticleSeoInput = {
  kind: "kegiatan",
  judul: artikel.judul,
  ringkasan: artikel.ringkasan,
  path,
  publishedAt: artikel.publishedAt,
  authorName: authorLabel,
  imageUrl: artikel.coverSrc,
  metaTitle: artikel.metaTitle,
  metaDescription: artikel.metaDescription,
  metaKeywords: artikel.metaKeywords,
  ogImageOverride: artikel.ogImageOverride,
};
const title = artikel.metaTitle?.trim() || artikel.judul;
const description = truncateMetaDescription(
  artikel.metaDescription?.trim() ||
    artikel.ringkasan ||
    "Berita SMK TEKNOVO",
);
const ogImage = artikel.ogImageOverride || artikel.coverSrc || undefined;
const publishedIso = artikel.publishedAt.toISOString();
---

<BaseLayout
  title={title}
  description={description}
  canonical={artikel.canonicalUrl || undefined}
  ogImage={ogImage}
  ogType="article"
  publishedTime={publishedIso}
  modifiedTime={publishedIso}
  authorName={authorLabel}
  articleSection={artikel.kategori || "Berita kegiatan"}
  keywords={artikel.metaKeywords || undefined}
>
  <BeritaArticleDetailShell
    client:load
    seo={seo}
    backHref="/berita/kegiatan-sekolah"
    backLabel="Berita kegiatan sekolah"
    sectionPath="/berita/kegiatan-sekolah"
    publishedAt={artikel.publishedAt}
    authorLabel={authorLabel}
    judul={artikel.judul}
    ringkasan={artikel.ringkasan}
    kontenHtml={sanitizeArtikelHtml(artikel.konten)}
    cover={{ src: artikel.coverSrc, alt: coverAlt }}
    related={related}
  />
</BaseLayout>
