---
import { ClientRouter } from "astro:transitions";
import { PublicFooterIsland } from "../components/PublicFooterIsland";
import { PublicNavbarIsland } from "../components/PublicNavbarIsland";
import { PublicSiteRuntime } from "../components/PublicSiteRuntime";
import { getPublicSiteMainNav } from "@/services/public-site-nav-publik";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  /** High-priority image URLs to preload (e.g. home hero LCP). */
  preloadImages?: string[];
  /**
   * Force-hide the three-tier marketing navbar (e.g. 404 full-bleed).
   * Default: hidden on beranda (`/`) which uses HeroOverlayNav instead.
   */
  hideNavbar?: boolean;
  /** Hide public footer (e.g. 404 full-bleed). */
  hideFooter?: boolean;
  /** Open Graph type — use `article` on berita/artikel detail. */
  ogType?: "website" | "article";
  ogLocale?: string;
  siteName?: string;
  publishedTime?: string;
  modifiedTime?: string;
  authorName?: string;
  articleSection?: string;
  keywords?: string;
  robots?: string;
};

const {
  title = "SMK TEKNOVO",
  description = "Portal resmi SMK TEKNOVO — Teknologi & Vokasional di Pamanukan Subang.",
  canonical,
  ogImage,
  preloadImages = [],
  hideNavbar: hideNavbarProp,
  hideFooter = false,
  ogType = "website",
  ogLocale = "id_ID",
  siteName = "SMK TEKNOVO",
  publishedTime,
  modifiedTime,
  authorName,
  articleSection,
  keywords,
  robots = "index, follow",
} = Astro.props;

const site = Astro.site?.href?.replace(/\/$/, "") || "https://smkteknovo.sch.id";
const url = canonical || new URL(Astro.url.pathname, site).href;
const r2Origin = (
  (typeof import.meta.env.PUBLIC_R2_URL === "string" &&
    import.meta.env.PUBLIC_R2_URL) ||
  "https://r2.ctos.web.id"
).replace(/\/$/, "");
const apiOrigin = (
  (typeof import.meta.env.PUBLIC_API_URL === "string" &&
    import.meta.env.PUBLIC_API_URL) ||
  "https://cf.smkteknovo.sch.id"
)
  .replace(/\/$/, "")
  .replace(/\/api$/, "");

const mainNav = await getPublicSiteMainNav();
const pathname = Astro.url.pathname || "/";
const hideNavbar =
  hideNavbarProp ?? (pathname === "/" || pathname === "");

const ogTitle = title.includes("TEKNOVO") ? title : `${title} | TEKNOVO`;
---

<!doctype html>
{/*
    Do NOT put transition:animate / transition:name on <html> or <main>.
    Even transition:animate="none" still assigns view-transition-name; the UA
    hides that live node during VT. If the transition is skipped (tab hidden),
    the page can stay invisible while the footer (root group) still paints.
  */}
<html lang="id" class="h-full antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    {keywords ? <meta name="keywords" content={keywords} /> : null}
    <link rel="canonical" href={url} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    {ogImage ? <meta property="og:image" content={ogImage} /> : null}
    {
      ogType === "article" && publishedTime ? (
        <meta property="article:published_time" content={publishedTime} />
      ) : null
    }
    {
      ogType === "article" && modifiedTime ? (
        <meta property="article:modified_time" content={modifiedTime} />
      ) : null
    }
    {
      ogType === "article" && authorName ? (
        <meta property="article:author" content={authorName} />
      ) : null
    }
    {
      ogType === "article" && articleSection ? (
        <meta property="article:section" content={articleSection} />
      ) : null
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage ? <meta name="twitter:image" content={ogImage} /> : null}
    <meta name="theme-color" content="#1313BA" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href={r2Origin} crossorigin />
    <link rel="preconnect" href={apiOrigin} crossorigin />
    <link rel="dns-prefetch" href={r2Origin} />
    <link rel="dns-prefetch" href={apiOrigin} />
    {
      preloadImages.map((href) => (
        <link rel="preload" as="image" href={href} fetchpriority="high" />
      ))
    }
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --font-poppins: "Poppins", ui-sans-serif, system-ui, sans-serif;
        --font-sans: var(--font-poppins);
      }
      body {
        font-family: var(--font-sans);
      }
    </style>
    <link rel="alternate" type="application/rss+xml" title="Berita SMK TEKNOVO" href="/rss.xml" />
    <!--
      Client-side MPA routing. fallback="swap" skips Astro's simulated fade path
      (data-astro-transition-fallback + fill-mode), which can leave
      .public-page-main at opacity:0 when a transition is interrupted by a tab
      switch. Native VT browsers still animate; recovery lives in lenis-page-nav.
    -->
    <ClientRouter fallback="swap" />
    <!-- Persistent Lenis ↔ ClientRouter sync + VT blank-main failsafe. -->
    <script src="../scripts/lenis-page-nav.ts"></script>
  </head>
  <body class="flex min-h-full flex-col bg-surface font-sans text-body text-foreground">
    {/*
      Chrome islands are SIBLINGS of page main — never wrap <slot /> in a React
      island. Nesting page islands inside PublicChrome caused ClientRouter
      remount hydration #418/#424 and wiped main while footer still painted.

      Do NOT put transition:animate / transition:name on html or main. Even
      transition:animate="none" still assigns a view-transition-name and the UA
      hides that live DOM node during VT (old pseudo gets opacity:0). When VT is
      skipped (tab hidden), the scoped node can stay invisible while the footer
      (root group) still paints — the live blank-homepage bug.
    */}
    <PublicSiteRuntime client:load />
    <PublicNavbarIsland
      client:load
      hidden={hideNavbar}
      pathname={pathname}
      mainNav={mainNav}
    />
    <main class="public-page-main min-w-0 flex-1 overflow-x-clip">
      <slot />
    </main>
    {hideFooter ? null : <PublicFooterIsland client:load />}
  </body>
</html>
