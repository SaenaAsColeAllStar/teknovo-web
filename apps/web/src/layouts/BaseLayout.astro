---
import { PublicChrome } from "../components/PublicChrome";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
};

const {
  title = "SMK TEKNOVO",
  description = "Portal resmi SMK TEKNOVO — Teknologi & Vokasional di Pamanukan Subang.",
  canonical,
  ogImage,
} = Astro.props;

const site = Astro.site?.href?.replace(/\/$/, "") || "https://smkteknovo.sch.id";
const url = canonical || new URL(Astro.url.pathname, site).href;
---

<!doctype html>
<html lang="id" data-scroll-behavior="smooth" class="h-full scroll-smooth antialiased">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    {ogImage ? <meta property="og:image" content={ogImage} /> : null}
    <meta name="theme-color" content="#1313BA" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      :root {
        --font-poppins: "Poppins", ui-sans-serif, system-ui, sans-serif;
        --font-sans: var(--font-poppins);
      }
      body {
        font-family: var(--font-sans);
      }
    </style>
    <link rel="alternate" type="application/rss+xml" title="Berita SMK TEKNOVO" href="/rss.xml" />
  </head>
  <body class="bg-surface font-sans text-body min-h-full">
    <PublicChrome client:load>
      <slot />
    </PublicChrome>
  </body>
</html>
