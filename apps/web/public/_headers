# Cloudflare Pages security + cache headers (static Astro deploy).
# CSP tuned for TEKNOVO public site — no Clerk on apps/web.
# script-src 'unsafe-inline': Astro client islands inject small inline bootstraps.
# No 'unsafe-eval' (not required by Astro/React islands here).

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; script-src 'self' 'unsafe-inline' https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: blob: https://r2.ctos.web.id; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://cf.smkteknovo.sch.id https://r2.ctos.web.id https://challenges.cloudflare.com https://turnstile-siteverify-teknovo-web.fajarnugrahayusman-06.workers.dev; media-src 'self' blob: https://r2.ctos.web.id; frame-src https://www.google.com https://maps.google.com https://challenges.cloudflare.com; upgrade-insecure-requests

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/*.svg
  Cache-Control: public, max-age=86400

/favicon.ico
  Cache-Control: public, max-age=86400

/favicon-*.png
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400
