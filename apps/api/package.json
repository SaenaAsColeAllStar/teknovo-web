{
  "name": "@teknovo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:node": "tsx watch src/server.ts",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "d1:migrate:local": "wrangler d1 migrations apply teknovo-article --local",
    "d1:migrate:remote": "wrangler d1 migrations apply teknovo-article --remote",
    "prisma:generate": "prisma generate && prisma generate --schema prisma-platform/schema.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:platform:generate": "prisma generate --schema prisma-platform/schema.prisma",
    "prisma:platform:migrate": "prisma migrate dev --schema prisma-platform/schema.prisma",
    "prisma:platform:deploy": "prisma migrate deploy --schema prisma-platform/schema.prisma",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:smoke": "tsx scripts/smoke-prisma-repos.ts",
    "prisma:procedures": "tsx scripts/deploy-stored-procedures.ts",
    "prisma:procedures:smoke": "tsx scripts/smoke-procedures.ts",
    "smoke:node": "tsx scripts/smoke-node-api.ts",
    "minio:ensure-bucket": "tsx scripts/ensure-minio-bucket.ts",
    "minio:seed": "tsx scripts/seed-minio.ts",
    "migrate:d1-to-pg:dry": "tsx scripts/migrate-d1-to-pg.ts",
    "migrate:d1-to-pg": "tsx scripts/migrate-d1-to-pg.ts --execute",
    "migrate:r2-objects:dry": "tsx scripts/migrate-r2-objects-to-minio.ts",
    "migrate:r2-objects": "tsx scripts/migrate-r2-objects-to-minio.ts --execute",
    "start:node": "tsx src/server.ts",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --update-env",
    "pm2:restart": "pm2 restart teknovo-api --update-env",
    "pm2:stop": "pm2 stop teknovo-api",
    "pm2:status": "pm2 status teknovo-api"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@clerk/backend": "^2.29.0",
    "@prisma/client": "^6.0.0",
    "@teknovo/shared": "workspace:*",
    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^5.0.0",
    "hono": "^4.9.0",
    "ioredis": "^5.6.1",
    "isomorphic-dompurify": "^2.26.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260717.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "wrangler": "^4.112.0"
  }
}
