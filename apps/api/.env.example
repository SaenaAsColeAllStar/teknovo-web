# ── Server (Node / VPS path — PRP) ──
PORT=8787
NODE_ENV=development
ENVIRONMENT=development

# ── PostgreSQL (docker-compose maps host 5434 → container 5432) ──
DATABASE_URL=postgresql://teknovo:teknovo@127.0.0.1:5434/teknovo?schema=public

# ── MinIO (docker-compose maps host 9010 → API 9000) ──
MINIO_ENDPOINT=127.0.0.1:9010
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=teknovo-web
MINIO_PUBLIC_URL=http://127.0.0.1:9010/teknovo-web
MINIO_REGION=auto

# ── D1 → Postgres migration (PRP Fase 7) ──
# R2_PUBLIC_URL=https://r2.ctos.web.id
# D1_DATABASE_NAME=teknovo-article
# MIGRATE_EXECUTE=1   # optional alt to --execute (prefer CLI flag)

# ── Clerk Auth ──
CLERK_SECRET_KEY=GANTI_sk_test_...
CLERK_WEBHOOK_SECRET=GANTI_whsec_...

# ── CORS ──
CMS_ORIGIN=http://localhost:5173
WEB_ORIGIN=http://localhost:4321

# ── Webhook Rebuild ──
REBUILD_WEB_SECRET=GANTI_rebuild_secret_min_16
GITHUB_REBUILD_TOKEN=
GITHUB_REPO=SaenaAsColeAllStar/teknovo-web
