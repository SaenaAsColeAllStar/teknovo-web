# ── Server (Node / VPS path — PRP) ──
PORT=8787
NODE_ENV=development
ENVIRONMENT=development

# ── PostgreSQL (docker-compose maps host 5434 → container 5432) ──
DATABASE_URL=postgresql://teknovo:teknovo@127.0.0.1:5434/teknovo?schema=public

# ── MinIO (docker-compose maps host 9010 → API 9000) ──
MINIO_ENDPOINT=127.0.0.1:9010
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=teknovo-web
MINIO_PUBLIC_URL=http://127.0.0.1:9010/teknovo-web
MINIO_REGION=auto

# ── D1 → Postgres migration (PRP Fase 7) ──
# R2_PUBLIC_URL=https://r2.ctos.web.id
# D1_DATABASE_NAME=teknovo-article
# MIGRATE_EXECUTE=1   # optional alt to --execute (prefer CLI flag)

# ── Clerk Auth ──
CLERK_SECRET_KEY=GANTI_sk_test_...
CLERK_WEBHOOK_SECRET=GANTI_whsec_...

# ── CORS ──
# Local:
CMS_ORIGIN=http://localhost:5173
WEB_ORIGIN=http://localhost:4321
# VPS production (Fase 8 cutover) — uncomment on the server:
# CMS_ORIGIN=https://cms.smkteknovo.sch.id
# WEB_ORIGIN=https://smkteknovo.sch.id
# ENVIRONMENT=production
# NODE_ENV=production
#
# Public hostname after Tunnel (clients use this — not set as bind address):
#   https://api.smkteknovo.sch.id  → cloudflared → 127.0.0.1:8787
# Keep Worker https://cf.smkteknovo.sch.id until cutover (docs/CUTOVER-API-TUNNEL.md).

# ── Webhook Rebuild ──
REBUILD_WEB_SECRET=GANTI_rebuild_secret_min_16
GITHUB_REBUILD_TOKEN=
GITHUB_REPO=SaenaAsColeAllStar/teknovo-web

# ── SaaS Platform foundation (PRP Fase 10) — OFF by default ──
# PLATFORM_ENABLED=false
# PLATFORM_DATABASE_URL=postgresql://teknovo:teknovo@127.0.0.1:5434/teknovo_platform
# REDIS_URL=redis://127.0.0.1:6379
# PLATFORM_SECRETS_KEY=GANTI_platform_secrets_key_min_16
# PLATFORM_ADMIN_SECRET=GANTI_platform_admin_bearer_min_16
# TENANT_DB_URL_TEMPLATE=postgresql://teknovo:teknovo@127.0.0.1:5434/{db}
