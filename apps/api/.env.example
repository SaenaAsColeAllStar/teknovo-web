# ── Server (Node / VPS path — PRP) ──
PORT=8788
NODE_ENV=development
ENVIRONMENT=development

# CATATAN PRODUKSI: secrets apps/api Node di VPS → aaPanel environment
# variables (PM2/site env), bukan file .env di disk. File ini = template lokal/migrate.

# ── PostgreSQL (aaPanel / external — NOT docker-compose) ──
DATABASE_URL=postgresql://GANTI_db_user:GANTI_db_password@127.0.0.1:5432/GANTI_db_name?schema=public

# ── MinIO (existing server container — S3 API host:port, no scheme) ──
# Host publish often 19000→9000; public TLS API may be storage-console.*; console UI storage.*
MINIO_ENDPOINT=127.0.0.1:19000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=GANTI_minio_access_key
MINIO_SECRET_KEY=GANTI_minio_secret_key
MINIO_BUCKET=GANTI_minio_bucket
# Path-style public base (include bucket if forcePathStyle)
MINIO_PUBLIC_URL=https://storage-console.smkteknovo.sch.id/GANTI_minio_bucket
MINIO_REGION=auto
# Informational: MINIO_BROWSER / console → https://storage.smkteknovo.sch.id
# Informational: MINIO_SERVER_URL / S3 API TLS → https://storage-console.smkteknovo.sch.id

# ── Redis (aaPanel / external — use DB index 10 for this project) ──
REDIS_URL=redis://:GANTI_redis_password@127.0.0.1:6379/10

# ── D1 → Postgres migration (PRP Fase 7) ──
# R2_PUBLIC_URL=https://r2.ctos.web.id
# D1_DATABASE_NAME=teknovo-article
# MIGRATE_EXECUTE=1   # optional alt to --execute (prefer CLI flag)
#
# R2 → MinIO object binaries (after or with URL rewrite):
# MIGRATE_OBJECTS_EXECUTE=1       # optional alt to migrate:r2-objects --execute
# MIGRATE_OBJECTS_CONCURRENCY=4
# SEED_SRC=https://r2.smkteknovo.sch.id # same as R2_PUBLIC_URL if unset
#
# Optional R2 S3 API (from root .env.local) — list/copy private objects:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=teknovo
#
# D1 export via wrangler (ops/migrate only; prefer aaPanel env in production):
# Token needs Account → D1 Edit/Read. Also set account id (same as R2_ACCOUNT_ID often).
CLOUDFLARE_API_TOKEN=GANTI_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=GANTI_cloudflare_account_id

# ── Clerk Auth ──
CLERK_SECRET_KEY=GANTI_sk_test_...
CLERK_WEBHOOK_SECRET=GANTI_whsec_...

# ── CORS ──
# Local:
CMS_ORIGIN=http://localhost:5173
WEB_ORIGIN=http://localhost:4321
# VPS production (Fase 8 cutover) — uncomment on the server:
# CMS_ORIGIN=https://cms.smkteknovo.sch.id
# WEB_ORIGIN=https://smkteknovo.sch.id
# ENVIRONMENT=production
# NODE_ENV=production
#
# Public hostname after Tunnel (clients use this — not set as bind address):
#   https://cms-api.smkteknovo.sch.id  → cloudflared → 127.0.0.1:8788
# Keep Worker https://cf.smkteknovo.sch.id until cutover (docs/CUTOVER-API-TUNNEL.md).

# ── Webhook Rebuild ──
REBUILD_WEB_SECRET=GANTI_rebuild_secret_min_16
GITHUB_REBUILD_TOKEN=
GITHUB_REPO=SaenaAsColeAllStar/teknovo-web

# ── SaaS Platform foundation (PRP Fase 10) — OFF by default ──
# PLATFORM_ENABLED=false
# PLATFORM_DATABASE_URL=postgresql://GANTI_db_user:GANTI_db_password@127.0.0.1:5432/GANTI_platform_db
# PLATFORM_SECRETS_KEY=GANTI_platform_secrets_key_min_16
# PLATFORM_ADMIN_SECRET=GANTI_platform_admin_bearer_min_16
# TENANT_DB_URL_TEMPLATE=postgresql://GANTI_db_user:GANTI_db_password@127.0.0.1:5432/{db}
# MINIO_PUBLIC_CMS_UPLOADS=1  # public GET for cms/uploads (R2 CDN parity)
