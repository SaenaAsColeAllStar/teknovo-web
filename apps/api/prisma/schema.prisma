// Tenant content schema — mirrors D1 migrations 0001–0004 (apps/api/migrations).
// Worker Free path still uses D1 until Fase 7 cutover.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BeritaStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ArtikelStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum SiteContentStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  REJECTED
  ARCHIVED
}

enum EkskulKategori {
  TEKNOLOGI
  OLAHRAGA
  AKADEMIK
  SENI
}

enum ProgramSekolahKategori {
  AKADEMIK
  NON_AKADEMIK
  KEAGAMAAN
}

enum PengumumanTipe {
  INFO
  WARNING
  URGENT
}

model Kategori {
  id          String   @id @default(uuid()) @db.Uuid
  nama        String
  slug        String   @unique
  deskripsi   String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  berita   Berita[]
  artikel  ArtikelSiswa[]

  @@map("kategori")
}

model Berita {
  id              String       @id @default(uuid()) @db.Uuid
  judul           String
  slug            String       @unique
  ringkasan       String?
  konten          String       @default("")
  coverUrl        String?      @map("cover_url")
  status          BeritaStatus @default(DRAFT)
  kategoriId      String?      @map("kategori_id") @db.Uuid
  metaTitle       String?      @map("meta_title")
  metaDescription String?      @map("meta_description")
  ogImageUrl      String?      @map("og_image_url")
  canonicalUrl    String?      @map("canonical_url")
  metaKeywords    String?      @map("meta_keywords")
  penulisId       String?      @map("penulis_id")
  penulisNama     String?      @map("penulis_nama")
  publishedAt     DateTime?    @map("published_at")
  /// Denormalized list key: COALESCE(published_at, created_at)
  sortAt          DateTime?    @map("sort_at")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  kategori Kategori? @relation(fields: [kategoriId], references: [id], onDelete: SetNull)

  @@index([status, sortAt(sort: Desc)], map: "idx_berita_status_sort_at")
  @@index([kategoriId], map: "idx_berita_kategori_id")
  @@map("berita")
}

model ArtikelSiswa {
  id              String        @id @default(uuid()) @db.Uuid
  judul           String
  slug            String        @unique
  ringkasan       String?
  konten          String        @default("")
  coverUrl        String?       @map("cover_url")
  status          ArtikelStatus @default(DRAFT)
  kategoriId      String?       @map("kategori_id") @db.Uuid
  penulisId       String        @map("penulis_id")
  penulisNama     String?       @map("penulis_nama")
  penulisKelas    String?       @map("penulis_kelas")
  rejectedReason  String?       @map("rejected_reason")
  submittedAt     DateTime?     @map("submitted_at")
  publishedAt     DateTime?     @map("published_at")
  metaTitle       String?       @map("meta_title")
  metaDescription String?       @map("meta_description")
  ogImageUrl      String?       @map("og_image_url")
  canonicalUrl    String?       @map("canonical_url")
  metaKeywords    String?       @map("meta_keywords")
  /// Denormalized list key: COALESCE(submitted_at, updated_at)
  sortAt          DateTime?     @map("sort_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  kategori Kategori? @relation(fields: [kategoriId], references: [id], onDelete: SetNull)

  @@index([status, sortAt(sort: Desc)], map: "idx_artikel_status_sort_at")
  @@index([penulisId, status], map: "idx_artikel_penulis_status")
  @@index([kategoriId], map: "idx_artikel_kategori_id")
  @@map("artikel_siswa")
}

model Fasilitas {
  id             String            @id @default(uuid()) @db.Uuid
  slug           String            @unique
  title          String
  navLabel       String            @map("nav_label")
  description    String            @default("")
  coverUrl       String?           @map("cover_url")
  highlightsJson Json              @default("[]") @map("highlights_json")
  paragraphsJson Json              @default("[]") @map("paragraphs_json")
  extrasJson     Json              @default("{}") @map("extras_json")
  layoutConfig   Json              @default("{\"showHero\":true,\"showFeatures\":true,\"showHours\":true,\"showStats\":false,\"layoutTemplate\":\"default\"}") @map("layout_config")
  sortOrder      Int               @default(0) @map("sort_order")
  showInNav      Boolean           @default(true) @map("show_in_nav")
  status         SiteContentStatus @default(DRAFT)
  reviewedBy     String?           @map("reviewed_by")
  reviewedAt     DateTime?         @map("reviewed_at")
  reviewNote     String?           @map("review_note")
  publishedAt    DateTime?         @map("published_at")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  @@index([status, sortOrder], map: "idx_fasilitas_status_sort")
  @@map("fasilitas")
}

model Ekstrakurikuler {
  id                        String            @id @default(uuid()) @db.Uuid
  slug                      String            @unique
  name                      String
  detail                    String            @default("")
  fullDescription           String            @default("") @map("full_description")
  kategori                  EkskulKategori
  previewUrl                String?           @map("preview_url")
  relatedAchievementsJson   Json              @default("[]") @map("related_achievements_json")
  jadwalRingkas             String?           @map("jadwal_ringkas")
  lokasiLatihan             String?           @map("lokasi_latihan")
  pembinaNama               String?           @map("pembina_nama")
  layoutConfig              Json              @default("{\"showHero\":true,\"showFeatures\":true,\"showHours\":true,\"showStats\":false,\"layoutTemplate\":\"default\"}") @map("layout_config")
  sortOrder                 Int               @default(0) @map("sort_order")
  status                    SiteContentStatus @default(DRAFT)
  reviewedBy                String?           @map("reviewed_by")
  reviewedAt                DateTime?         @map("reviewed_at")
  reviewNote                String?           @map("review_note")
  publishedAt               DateTime?         @map("published_at")
  createdAt                 DateTime          @default(now()) @map("created_at")
  updatedAt                 DateTime          @updatedAt @map("updated_at")

  @@index([status, sortOrder], map: "idx_ekstrakurikuler_status_sort")
  @@map("ekstrakurikuler")
}

model Prestasi {
  id            String            @id @default(uuid()) @db.Uuid
  judul         String
  penyelenggara String            @default("")
  tanggalIso    DateTime          @map("tanggal_iso") @db.Date
  siswaLabel    String            @default("") @map("siswa_label")
  ringkasan     String            @default("")
  fileUrl       String            @map("file_url")
  layoutConfig  Json              @default("{\"showHero\":true,\"showFeatures\":true,\"showHours\":true,\"showStats\":false,\"layoutTemplate\":\"default\"}") @map("layout_config")
  sortOrder     Int               @default(0) @map("sort_order")
  status        SiteContentStatus @default(DRAFT)
  reviewedBy    String?           @map("reviewed_by")
  reviewedAt    DateTime?         @map("reviewed_at")
  reviewNote    String?           @map("review_note")
  publishedAt   DateTime?         @map("published_at")
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")

  @@index([status, sortOrder, tanggalIso(sort: Desc)], map: "idx_prestasi_status_sort_tanggal")
  @@map("prestasi")
}

model Kurikulum {
  id                 String            @id @default(uuid()) @db.Uuid
  judul              String
  slug               String            @unique
  deskripsi          String            @default("") @db.Text
  coverUrl           String?           @map("cover_url")
  dokumenUrl         String?           @map("dokumen_url")
  tahunAjaran        String            @map("tahun_ajaran")
  jurusan            String[]          @default([])
  strukturKurikulum  Json?             @map("struktur_kurikulum")
  layoutConfig       Json              @default("{\"showHero\":true,\"showFeatures\":true,\"showHours\":true,\"showStats\":false,\"layoutTemplate\":\"default\"}") @map("layout_config")
  sortOrder          Int               @default(0) @map("sort_order")
  showInNav          Boolean           @default(true) @map("show_in_nav")
  status             SiteContentStatus @default(DRAFT)
  reviewedBy         String?           @map("reviewed_by")
  reviewedAt         DateTime?         @map("reviewed_at")
  reviewNote         String?           @map("review_note")
  publishedAt        DateTime?         @map("published_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  @@index([status, sortOrder], map: "idx_kurikulum_status_sort")
  @@map("kurikulum")
}

model ProgramSekolah {
  id              String                  @id @default(uuid()) @db.Uuid
  judul           String
  slug            String                  @unique
  deskripsi       String                  @default("") @db.Text
  coverUrl        String?                 @map("cover_url")
  ikon            String?
  kategori        ProgramSekolahKategori
  highlightItems  String[]                @default([]) @map("highlight_items")
  layoutConfig    Json                    @default("{\"showHero\":true,\"showFeatures\":true,\"showHours\":true,\"showStats\":false,\"layoutTemplate\":\"default\"}") @map("layout_config")
  sortOrder       Int                     @default(0) @map("sort_order")
  showInNav       Boolean                 @default(true) @map("show_in_nav")
  status          SiteContentStatus       @default(DRAFT)
  reviewedBy      String?                 @map("reviewed_by")
  reviewedAt      DateTime?               @map("reviewed_at")
  reviewNote      String?                 @map("review_note")
  publishedAt     DateTime?               @map("published_at")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  @@index([status, sortOrder], map: "idx_program_sekolah_status_sort")
  @@map("program_sekolah")
}

model ProgramJurusan {
  id               String            @id @default(uuid()) @db.Uuid
  nama             String
  slug             String            @unique
  singkatan        String
  deskripsi        String            @default("") @db.Text
  coverUrl         String?           @map("cover_url")
  ikon             String?
  prospekKerja     String[]          @default([]) @map("prospek_kerja")
  kompetensiDasar  String[]          @default([]) @map("kompetensi_dasar")
  fasilitas        String[]          @default([])
  jumlahSiswa      Int?              @map("jumlah_siswa")
  linkPendaftaran  String?           @map("link_pendaftaran")
  layoutConfig     Json              @default("{\"showHero\":true,\"showFeatures\":true,\"showHours\":true,\"showStats\":false,\"layoutTemplate\":\"default\"}") @map("layout_config")
  sortOrder        Int               @default(0) @map("sort_order")
  showInNav        Boolean           @default(true) @map("show_in_nav")
  status           SiteContentStatus @default(DRAFT)
  reviewedBy       String?           @map("reviewed_by")
  reviewedAt       DateTime?         @map("reviewed_at")
  reviewNote       String?           @map("review_note")
  publishedAt      DateTime?         @map("published_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  @@index([status, sortOrder], map: "idx_program_jurusan_status_sort")
  @@map("program_jurusan")
}

model TenagaPengajar {
  id              String            @id @default(uuid()) @db.Uuid
  nama            String
  slug            String            @unique
  nip             String?
  fotoUrl         String?           @map("foto_url")
  jabatan         String
  bidangKeahlian  String?           @map("bidang_keahlian")
  mataPelajaran   String[]          @default([]) @map("mata_pelajaran")
  pendidikan      String?
  pengalaman      String?           @db.Text
  kontakEmail     String?           @map("kontak_email")
  mediaSosial     Json?             @map("media_sosial")
  layoutConfig    Json              @default("{\"showHero\":true,\"showFeatures\":true,\"showHours\":true,\"showStats\":false,\"layoutTemplate\":\"default\"}") @map("layout_config")
  sortOrder       Int               @default(0) @map("sort_order")
  showInNav       Boolean           @default(true) @map("show_in_nav")
  status          SiteContentStatus @default(DRAFT)
  reviewedBy      String?           @map("reviewed_by")
  reviewedAt      DateTime?         @map("reviewed_at")
  reviewNote      String?           @map("review_note")
  publishedAt     DateTime?         @map("published_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([status, sortOrder], map: "idx_tenaga_pengajar_status_sort")
  @@map("tenaga_pengajar")
}

model Kontak {
  id              String            @id @default(uuid()) @db.Uuid
  label           String
  slug            String            @unique
  alamatLengkap   String            @map("alamat_lengkap") @db.Text
  telepon         String[]          @default([])
  email           String[]          @default([])
  whatsapp        String?
  googleMapsUrl   String?           @map("google_maps_url")
  googleMapsEmbed String?           @map("google_maps_embed") @db.Text
  jamOperasional  Json?             @map("jam_operasional")
  mediaSosial     Json?             @map("media_sosial")
  layoutConfig    Json              @default("{\"showHero\":true,\"showFeatures\":true,\"showHours\":true,\"showStats\":false,\"layoutTemplate\":\"default\"}") @map("layout_config")
  sortOrder       Int               @default(0) @map("sort_order")
  showInNav       Boolean           @default(true) @map("show_in_nav")
  status          SiteContentStatus @default(PUBLISHED)
  reviewedBy      String?           @map("reviewed_by")
  reviewedAt      DateTime?         @map("reviewed_at")
  reviewNote      String?           @map("review_note")
  publishedAt     DateTime?         @map("published_at")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")

  @@index([status, sortOrder], map: "idx_kontak_status_sort")
  @@map("kontak")
}

model Pengumuman {
  id           String            @id @default(uuid()) @db.Uuid
  judul        String
  slug         String            @unique
  konten       String            @default("") @db.Text
  tipe         PengumumanTipe    @default(INFO)
  bannerUrl    String?           @map("banner_url")
  tanggalMulai DateTime?         @map("tanggal_mulai")
  tanggalAkhir DateTime?         @map("tanggal_akhir")
  isSticky     Boolean           @default(false) @map("is_sticky")
  layoutConfig Json              @default("{\"showHero\":true,\"showFeatures\":true,\"showHours\":true,\"showStats\":false,\"layoutTemplate\":\"default\"}") @map("layout_config")
  sortOrder    Int               @default(0) @map("sort_order")
  status       SiteContentStatus @default(DRAFT)
  reviewedBy   String?           @map("reviewed_by")
  reviewedAt   DateTime?         @map("reviewed_at")
  reviewNote   String?           @map("review_note")
  publishedAt  DateTime?         @map("published_at")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  @@index([status, sortOrder], map: "idx_pengumuman_status_sort")
  @@index([isSticky, status], map: "idx_pengumuman_sticky_status")
  @@map("pengumuman")
}

model SiteMedia {
  mediaKey  String   @id @map("media_key")
  label     String
  category  String   @default("landing")
  url       String
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@index([category], map: "idx_site_media_category")
  @@map("site_media")
}

model Pengaturan {
  id        String   @id @db.Uuid
  payload   Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("pengaturan")
}
