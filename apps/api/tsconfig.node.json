{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@teknovo/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": [
    "src/server.ts",
    "src/index.ts",
    "src/auth/**/*.ts",
    "src/routes/**/*.ts",
    "src/media/**/*.ts",
    "src/lib/**/*.ts",
    "src/middleware/**/*.ts",
    "src/generated/platform-client/**/*.ts",
    "scripts/**/*.ts",
    "prisma/seed.ts",
    "worker-configuration.d.ts"
  ],
  "exclude": ["src/**/*.test.ts", "node_modules", "dist"]
}
