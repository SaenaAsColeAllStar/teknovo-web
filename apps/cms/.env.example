VITE_CLERK_PUBLISHABLE_KEY=GANTI_CLERK_PUBLISHABLE_KEY
# Preferred CMS Pages var (host-only also OK). Not PUBLIC_API_URL — that name is for Astro/web.
VITE_API_URL=https://cf.smkteknovo.sch.id/api
VITE_R2_PUBLIC_URL=https://r2.ctos.web.id
# Public marketing site (login “Kembali ke situs” link). Defaults to apex if unset.
VITE_WEB_ORIGIN=https://smkteknovo.sch.id

# Cloudflare Turnstile (password sign-in). Sitekey is public; secret stays on the Worker.
VITE_TURNSTILE_SITEKEY=GANTI_turnstile_sitekey
VITE_TURNSTILE_SITEVERIFY_URL=https://turnstile-siteverify-teknovo-web.fajarnugrahayusman-06.workers.dev

# SaaS platform admin UI (PRP Fase 10) — OFF by default; requires Node API PLATFORM_ENABLED
# VITE_PLATFORM_ENABLED=true
