# Cloudflare Pages security headers for CMS (Vite SPA + Clerk).
# Clerk needs style-src 'unsafe-inline' (CSS-in-JS) and script-src 'unsafe-inline'
# for its bootstrap. Production Clerk docs: omit 'unsafe-eval' (Vite build does not need it).
# FAPI host: clerk.smkteknovo.sch.id (custom). Google OAuth frames: accounts.google.com.

/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self' https://accounts.google.com https://clerk.smkteknovo.sch.id https://*.clerk.accounts.dev; script-src 'self' 'unsafe-inline' https://clerk.smkteknovo.sch.id https://*.clerk.accounts.dev https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://img.clerk.com https://r2.ctos.web.id; font-src 'self' data:; connect-src 'self' https://cf.smkteknovo.sch.id https://r2.ctos.web.id https://clerk.smkteknovo.sch.id https://*.clerk.accounts.dev https://clerk-telemetry.com https://*.clerk-telemetry.com https://challenges.cloudflare.com https://turnstile-siteverify-teknovo-web.fajarnugrahayusman-06.workers.dev; worker-src 'self' blob:; frame-src 'self' https://clerk.smkteknovo.sch.id https://*.clerk.accounts.dev https://challenges.cloudflare.com https://accounts.google.com; upgrade-insecure-requests

/assets/*
  Cache-Control: public, max-age=31536000, immutable
