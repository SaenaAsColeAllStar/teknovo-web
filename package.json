{
  "name": "teknovo-web",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "dev:api": "pnpm --filter @teknovo/api dev",
    "dev:api:node": "pnpm --filter @teknovo/api dev:node",
    "dev:cms": "pnpm --filter @teknovo/cms dev",
    "dev:web": "pnpm --filter @teknovo/web dev",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "build:api": "pnpm --filter @teknovo/api exec wrangler deploy --dry-run --outdir=/tmp/teknovo-api-dry 2>/dev/null || true",
    "build:cms": "pnpm --filter @teknovo/cms build",
    "build:web": "pnpm --filter @teknovo/web build",
    "deploy:api": "pnpm --filter @teknovo/api deploy",
    "deploy:cms": "pnpm --filter @teknovo/cms deploy",
    "deploy:web": "pnpm --filter @teknovo/web deploy",
    "legacy:dev": "next dev --port 3000",
    "legacy:build": "next build",
    "legacy:build:cf": "pnpm cf-typegen && opennextjs-cloudflare build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:api": "pnpm --filter @teknovo/api test",
    "d1:migrate:remote": "pnpm --filter @teknovo/api d1:migrate:remote",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.5.20",
    "@hookform/resolvers": "^5.4.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@tanstack/react-query": "^5.101.2",
    "@tiptap/pm": "^3.28.0",
    "@tiptap/react": "^3.28.0",
    "@tiptap/starter-kit": "^3.28.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "feed": "^6.0.0",
    "framer-motion": "^12.38.0",
    "gsap": "^3.15.0",
    "isomorphic-dompurify": "^3.19.0",
    "lenis": "^1.3.25",
    "lucide-react": "^1.25.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.81.0",
    "recharts": "^3.9.2",
    "schema-dts": "^2.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260717.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.112.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/client",
      "@prisma/engines"
    ]
  }
}
