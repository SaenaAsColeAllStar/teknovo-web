# ─── Split Free (preferred) — see DEPLOY.md ───────────
# Apex Astro / Pages project teknovo-web (apps/web/.env.example):
#   PUBLIC_API_URL=https://cf.smkteknovo.sch.id   ← host only, NO /api
#   PUBLIC_SITE_URL=https://smkteknovo.sch.id
#   PUBLIC_R2_URL=https://r2.ctos.web.id
#   PUBLIC_TURNSTILE_SITEKEY=GANTI_turnstile_sitekey
#   PUBLIC_TURNSTILE_SITEVERIFY_URL=https://turnstile-siteverify-teknovo-web.fajarnugrahayusman-06.workers.dev
# CMS Vite / Pages project teknovo-cms (apps/cms/.env.example):
#   VITE_API_URL=https://cf.smkteknovo.sch.id/api  ← preferred (…/api or host-only)
#   VITE_CLERK_PUBLISHABLE_KEY=…
#   (+ VITE_TURNSTILE_*). PUBLIC_API_URL accepted as CMS build fallback only.
# API secrets via wrangler secret (CLERK_SECRET_KEY, GITHUB_REBUILD_TOKEN, …)
# Turnstile secret: only on Worker turnstile-siteverify-teknovo-web (TURNSTILE_SECRET_KEY)

# ─── Legacy Next monolit (optional local) ─────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Homelab api-web (opsional — kosongkan untuk pakai D1 same-origin)
# API_URL=http://127.0.0.1:4010
# NEXT_PUBLIC_API_URL=http://127.0.0.1:4010
# Default CMS: Cloudflare D1 `teknovo-article` via /api/v1/* (binding DB)

# ─── Clerk (https://dashboard.clerk.com) ───────────────
# Publishable/secret keys only — never use DB/D1 passwords as Clerk user passwords.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=GANTI_pk_test_...
CLERK_SECRET_KEY=GANTI_sk_test_...
CLERK_WEBHOOK_SECRET=GANTI_whsec_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# CMS roles (Clerk publicMetadata.role): admin | editor | viewer | siswa
# siswa = artikel milik sendiri + upload media; bukan berita sekolah / moderasi
# Bootstrap Super Admin: node --env-file=.env.local scripts/bootstrap-super-admin.mjs diegocole234@gmail.com

# ─── Cloudflare R2 (CMS content + media) ───────────────
# Bucket binding: CMS_BUCKET → "teknovo" (see wrangler.toml)
# Account ID: set CLOUDFLARE_ACCOUNT_ID in CI / local env (wrangler whoami) — do not commit real IDs.
# Public custom domain must match the R2 custom domain on THIS account.
# Migrasi aset dari CDN lama: bash scripts/migrate-r2-from-public-cdn.sh
# Sync penuh antar akun: rclone + R2 API tokens (sumber + tujuan)
# R2_ACCESS_KEY_ID=GANTI_access_key
# R2_SECRET_ACCESS_KEY=GANTI_secret_key

# ─── Revalidation ──────────────────────────────────────
REVALIDATE_SECRET=GANTI_revalidate_secret
