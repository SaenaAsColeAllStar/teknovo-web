# ─── App ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Homelab / future api-web base URL (no trailing slash)
API_URL=http://127.0.0.1:4010
NEXT_PUBLIC_API_URL=http://127.0.0.1:4010

# ─── Clerk (https://dashboard.clerk.com) ───────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=GANTI_pk_test_...
CLERK_SECRET_KEY=GANTI_sk_test_...
CLERK_WEBHOOK_SECRET=GANTI_whsec_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ─── Cloudflare R2 (CMS content + media) ───────────────
# Bucket binding: CMS_BUCKET → "teknovo" (see wrangler.toml)
# Public custom domain must match the R2 custom domain.
R2_BUCKET_NAME=teknovo
R2_PUBLIC_URL=https://r2.ctos.web.id
R2_ACCOUNT_ID=GANTI_account_id
# S3 API keys — hanya jika akses R2 di luar Workers binding (CLI/script)
# R2_ACCESS_KEY_ID=GANTI_access_key
# R2_SECRET_ACCESS_KEY=GANTI_secret_key

# ─── Revalidation ──────────────────────────────────────
REVALIDATE_SECRET=GANTI_revalidate_secret
