# ─── Split Free (preferred) — see DEPLOY.md ───────────
# Apex Astro: PUBLIC_API_URL=https://cf.smkteknovo.sch.id
# CMS Vite:   apps/cms/.env → VITE_API_URL + VITE_CLERK_PUBLISHABLE_KEY
# API secrets via wrangler secret (CLERK_SECRET_KEY, GITHUB_REBUILD_TOKEN, …)

# ─── Legacy Next monolit (optional local) ─────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Homelab api-web (opsional — kosongkan untuk pakai D1 same-origin)
# API_URL=http://127.0.0.1:4010
# NEXT_PUBLIC_API_URL=http://127.0.0.1:4010
# Default CMS: Cloudflare D1 `teknovo-article` via /api/v1/* (binding DB)

# ─── Clerk (https://dashboard.clerk.com) ───────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=GANTI_pk_test_...
CLERK_SECRET_KEY=GANTI_sk_test_...
CLERK_WEBHOOK_SECRET=GANTI_whsec_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
# CMS roles (Clerk publicMetadata.role): admin | editor | viewer | siswa
# siswa = artikel milik sendiri + upload media; bukan berita sekolah / moderasi

# ─── Cloudflare R2 (CMS content + media) ───────────────
# Bucket binding: CMS_BUCKET → "teknovo" (see wrangler.toml)
# Account aktif (wrangler whoami): 3187c008103471713510934f5ff2e7cf
# Public custom domain must match the R2 custom domain on THIS account.
# Migrasi aset dari CDN lama: bash scripts/migrate-r2-from-public-cdn.sh
# Sync penuh antar akun: rclone + R2 API tokens (sumber + tujuan)
# R2_ACCESS_KEY_ID=GANTI_access_key
# R2_SECRET_ACCESS_KEY=GANTI_secret_key

# ─── Revalidation ──────────────────────────────────────
REVALIDATE_SECRET=GANTI_revalidate_secret
